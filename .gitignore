# ============================================================
# SwordigoDesktop — Comprehensive .gitignore for GitHub Release
# ============================================================

# -------- BUILDS / OUTPUTS / BINARIES --------
# Compiled project binaries (project-created)
swordigo_boot
swordigo_headless
loader_test
analyze_syms
check_relocations
find_bad_ptr
verify_0x10000000
poc_loader

# Object files and shared libraries
*.o
*.so
*.so.*

# Archives
*.zip
*.tar
*.tar.*
*.xz
*.gz
*.7z

# Build outputs directory
build/
out/

# -------- LOGS / COREDUMPS / RUNTIME DATA --------
# Logs from testing and debugging
*.log
*.core

# Caches, saves (runtime data, not source)
cache/
save/
*.ppm

# -------- PROPRIETARY GAME BINARY --------
# Extracted from the original APK — DO NOT DISTRIBUTE
libswordigo.so
libswordigo_patched.so
libswordigo64.so
libswordigo*.so
rl_libswordigo.so
rl_libmini.so
rl_libGlossHook.so
rl_*.so

# -------- TRACES / SYMBOLS --------
symbols_*.txt
trace_log.txt
background_prepare.txt
CLEANUP_REPORT.md
assets.tar*

# -------- PROPRIETARY REFERENCE MATERIALS --------
# (decompiled code, extracted resources, proprietary libraries, etc.)
reference/
reference/**

# -------- EXTRACTED GAME ASSETS --------
# Commercial game assets extracted from the APK
assets/resources/
rl_assets/
assets/dexopt/
dexopt/
*.wav
*.pvr
*.POD
*.scene
*.scl
*.gdata
*.gstate
*.gopt
*.proto
*.fnt
*.atlas

# Keep the README which has license attributions
!assets/README

# -------- BUILDER ARTIFACTS --------
builder/appimage/Swordigo.AppDir/
builder/appimage/Swordigo-x86_64.AppImage
builder/appimage/appimagetool
builder/flatpak/.flatpak-builder/
builder/flatpak/repo/
builder/flatpak/export/
packaging/deb/usr/
packaging/
*.deb
*.rpm

# -------- INTERNAL AGENT PROMPTS --------
prompt/

# -------- DEVELOPMENT TOOLS (JADX, SRCC) --------
.tools/

# -------- IDE CONFIGS --------
.idea/
*.iml
*.desktop

# -------- OS ARTIFACTS --------
.DS_Store
Thumbs.db

# -------- ANDROID NDK (large download) --------
android-ndk-*-linux.zip

# ------------- EXTERNAL THIRD-PARTY RESEARCH --------
# Vita port (separate third-party project)
docs/research/vita/vistaPort/

# -------- FORENSIC / DEBUG TOOLS --------
# ELF analysis binaries (internal tools)
analyze_syms
check_relocations
find_bad_ptr
verify_0x10000000

# POC loader (ARM static binary test)
poc_loader

# Python research scripts
generate_poc.py

# -------- OTHER --------
# Docs research archives
docs/research/vita/*.zip
